# Team gate (simple shared PIN for v1)
DASH_ACCESS_PIN=3121

# Meta Marketing API — READ ONLY / review
# Never use a token with ads_management write if avoidable.
META_ACCESS_TOKEN=
META_API_VERSION=v21.0

# Google Ads API — READ ONLY
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=
GOOGLE_ADS_API_VERSION=v21
# Keep false until developer-token/project is allowed. Credentials can exist while live is off.
GOOGLE_ADS_LIVE=false
GOOGLE_ADS_CUSTOMER_IDS=
# Per-client Google customer IDs (no dashes)
GADS_BRANDASTIC=
GADS_FRIAR_TUX=
GADS_DESS=
GADS_NORDIC=
GADS_CINI=
GADS_AAH=
GADS_ATOMIC=
GADS_CHPM=

# Optional: force demo metrics even if tokens exist
FORCE_DEMO_DATA=false

# xAI (Grok) — AI recommendations engine
XAI_API_KEY=
XAI_MODEL=grok-4.5
XAI_API_BASE=https://api.x.ai/v1

# Client logo uploads (Vercel Blob)
BLOB_READ_WRITE_TOKEN=


# Semrush SEO (read-only domain overview + organic keywords)
SEMRUSH_API_KEY=
SEMRUSH_DATABASE=us
# Optional per-client domain overrides
SEO_DOMAIN_BRANDASTIC=brandastic.com
SEO_DOMAIN_FRIAR_TUX=friartux.com
SEO_DOMAIN_DESS=dess-usa.com
SEO_DOMAIN_NORDIC=nordicsauna.com
SEO_DOMAIN_CINI=cinisauce.com
SEO_DOMAIN_AAH=adoptahighway.com
SEO_DOMAIN_ATOMIC=atomichorseradish.com
SEO_DOMAIN_CHPM=hoame.com
