# Team gate (simple shared PIN for v1)
DASH_ACCESS_PIN=3121

# Meta Marketing API — READ ONLY / review
# Never use a token with ads_management write if avoidable.
META_ACCESS_TOKEN=
META_API_VERSION=v21.0

# Google Ads API — READ ONLY
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=
GOOGLE_ADS_CUSTOMER_IDS=

# Optional: force demo metrics even if tokens exist
FORCE_DEMO_DATA=false

# xAI (Grok) — AI recommendations engine
XAI_API_KEY=
XAI_MODEL=grok-4.5
XAI_API_BASE=https://api.x.ai/v1

# Client logo uploads (Vercel Blob)
BLOB_READ_WRITE_TOKEN=
